VITE_AUTH_MODE=entra
VITE_API_BASE=
# Replace with real Entra app registration values before production deploy.
# Placeholders must keep the YOUR_ prefix so fail-closed auth gates refuse shipping.
VITE_ENTRA_CLIENT_ID=YOUR_ENTRA_CLIENT_ID
VITE_ENTRA_TENANT_ID=YOUR_ENTRA_TENANT_ID
VITE_ENTRA_API_SCOPE=api://YOUR_ENTRA_API_CLIENT_ID/.default
# Leave empty to use window.location.origin at runtime (must be HTTPS in real deploy).
VITE_ENTRA_REDIRECT_URI=

{
  "ConnectionStrings": {
    "Baseera": "Server=127.0.0.1,1433;Database=Baseera;User Id=sa;Password=YOUR_LOCAL_SA_PASSWORD;Encrypt=False;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Auth": {
    "UseTestAuth": true
  },
  "AzureAd": {
    "Instance": "https://login.microsoftonline.com/",
    "TenantId": "YOUR_TENANT_ID",
    "ClientId": "YOUR_API_CLIENT_ID",
    "Audience": "api://YOUR_API_CLIENT_ID"
  },
  "Cors": {
    "Origins": [ "http://localhost:5173" ]
  },
  "Attachments": {
    "RootPath": "data/attachments"
  },
  "Seed": {
    "DemoOrganization": true
  },
  "Database": {
    "ApplyMigrationsOnStartup": true
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
